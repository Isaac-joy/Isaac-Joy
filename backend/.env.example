# ── Supabase ── (Project Settings → API)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
# service_role is a SECRET. Backend ONLY. NEVER ship it inside the mobile app.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# ── Gemini (free tier) ── https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# ── OpenRouter (free) ── https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL=openai/gpt-oss-120b:free
# Synthesizer failover pool (comma-separated, tried in order; auto-shift on busy/error):
OPENROUTER_MODELS=openai/gpt-oss-120b:free,meta-llama/llama-3.3-70b-instruct:free,qwen/qwen3-next-80b-a3b-instruct:free,z-ai/glm-4.5-air:free
# Council fallbacks used only if Gemini is busy/unavailable:
COUNCIL_FALLBACK_MODELS=openai/gpt-oss-120b:free,meta-llama/llama-3.3-70b-instruct:free

# ── Tuning ──
MAX_ATTEMPTS=3
JSON_RETRIES=3
WORKER_POLL_SECONDS=5
LLM_TIMEOUT_SECONDS=120
# Per-user daily cap — protects the shared free-tier quota.
MAX_SUBMISSIONS_PER_USER_PER_DAY=3
# How many reports to process in parallel.
WORKER_CONCURRENCY=3
# Comma-separated origins, or * for all (tighten for production).
CORS_ORIGINS=*
