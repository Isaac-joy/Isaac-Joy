# ── Supabase ── (Project Settings → API)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
# service_role is a SECRET. Backend ONLY. NEVER ship it inside the mobile app.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# ── Gemini (free tier) ── https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# ── DeepSeek R1 via OpenRouter (free) ── https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL=openai/gpt-oss-120b:free
OPENROUTER_REFERER=https://solo-leveling-council.app
OPENROUTER_TITLE=Solo Leveling Council

# ── Tuning ──
MAX_ATTEMPTS=3
JSON_RETRIES=3
WORKER_POLL_SECONDS=5
LLM_TIMEOUT_SECONDS=120
# Per-user daily cap — protects the shared ~50/day free-tier quota.
MAX_SUBMISSIONS_PER_USER_PER_DAY=3
# Comma-separated origins, or * for all (tighten for production).
CORS_ORIGINS=*
